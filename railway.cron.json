{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bun install --frozen-lockfile && bun run typecheck && bun run build"
  },
  "deploy": {
    "startCommand": "bun run bench:record",
    "cronSchedule": "*/5 * * * *",
    "restartPolicyType": "NEVER"
  }
}
